# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role bypasses RLS; never expose to the client or commit.
SUPABASE_SERVICE_ROLE_KEY=

# Single Supabase Auth user UUID that owns all household rows (recipes, meal_plans, cooked_logs).
# Create one user in Supabase Dashboard → Authentication → Users, then paste their UUID here.
VAULT_HOUSEHOLD_USER_ID=

# Passphrase guests type to unlock the app (not the Supabase password).
VAULT_PASSPHRASE=

# Random long secret to sign the httpOnly session cookie (e.g. openssl rand -hex 32).
VAULT_SESSION_SECRET=
